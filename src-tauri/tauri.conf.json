{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cashbook",
  "version": "0.1.0",
  "identifier": "com.ngangman-teddy.cashbook",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cashbook",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/<your-username>/<repo-name>/releases/latest/download/latest.json"],
      "dialog": true,
      "pubkey": "<YOUR_ED25519_PUBLIC_KEY>"
    }
  }
}
